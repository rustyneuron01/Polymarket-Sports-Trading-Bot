# Polymarket NHL Bot — copy to .env and adjust

PREDICT_ALL_GAMES=true
PAPER_TRADING=true
COLLECTOR_POLL_INTERVAL_SEC=60

# In-game: we predict the price path; no fixed targets by default. Optional fallback (see DOCS.md §2):
# IN_GAME_USE_FIXED_TARGETS=0
# IN_GAME_BUY_PRICE_TARGET=0.20
# IN_GAME_SELL_PRICE_TARGET=0.70

# Live trading: set PAPER_TRADING=false and add your key (EOA wallet)
# POLYMARKET_PRIVATE_KEY=your_hex_private_key
# Optional for proxy/email wallets: POLYMARKET_FUNDER=0x...

# Polymarket API key (optional): set in .env for authenticated requests; never commit .env
# POLYMARKET_API_KEY=your-api-key-here
# POLYMARKET_API_SECRET=your-api-secret-if-you-have-one
